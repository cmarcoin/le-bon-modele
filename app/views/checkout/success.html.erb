<% content_for :title, "Paiement confirmé | Le Bon Modèle" %>

<%= render "home/header" %>

<main class="relative pt-28">
  <%= render "home/background_pattern" %>
  <section class="relative px-4 py-16 md:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl rounded-[28px] border border-[#E7E2DC] bg-white p-8 text-center shadow-soft lg:p-12">
      <p class="text-[20px] font-bold text-brand-primary">Paiement confirmé</p>
      <h1 class="mt-3 font-heading text-[42px] font-bold leading-none text-brand-text sm:text-[56px]">Votre rendez-vous est réservé</h1>

      <% if @booking&.paid? %>
        <p class="mx-auto mt-6 max-w-2xl text-[20px] leading-[1.5] text-brand-text-secondary">
          Merci <%= @booking.customer_name %>. Nous avons bien reçu votre paiement pour <%= @booking.pack.name %>.
          Rendez-vous le <strong><%= paris_datetime(@booking.availability_slot.starts_at) %></strong>
          avec <%= @booking.availability_slot.colleague_name %>.
        </p>
        <p class="mt-4 text-brand-text-secondary">Un email de confirmation vient de vous être envoyé.</p>
      <% else %>
        <p class="mx-auto mt-6 max-w-2xl text-[20px] leading-[1.5] text-brand-text-secondary">
          Stripe a bien redirigé votre paiement. La confirmation définitive arrivera dès que le webhook Stripe aura validé la transaction.
        </p>
      <% end %>

      <%= link_to "Retour à l'accueil", root_path, class: "mt-8 inline-flex min-h-[58px] items-center justify-center rounded-full bg-brand-primary px-8 text-[18px] font-bold text-white" %>
    </div>
  </section>
</main>

<%= render "home/footer" %>
