<% if notice.present? || alert.present? %>
  <div
    class="<%= local_assigns.fetch(:class, "mx-auto max-w-3xl px-6 py-3") %> space-y-2 transition-opacity duration-200"
    data-controller="flash"
    data-flash-dismiss-after-value="5000"
    role="status"
    aria-live="polite"
  >
    <% if notice.present? %>
      <div class="flex items-center gap-3 rounded-full border border-brand-primary/20 bg-white px-5 py-3 text-sm font-bold text-brand-primary shadow-soft">
        <p class="flex-1"><%= notice %></p>
        <button type="button" class="shrink-0 rounded-full p-1 text-brand-primary/60 transition hover:text-brand-primary" aria-label="Fermer" data-action="flash#dismiss">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="flex items-center gap-3 rounded-full border border-brand-coral/30 bg-white px-5 py-3 text-sm font-bold text-brand-coral shadow-soft">
        <p class="flex-1"><%= alert %></p>
        <button type="button" class="shrink-0 rounded-full p-1 text-brand-coral/60 transition hover:text-brand-coral" aria-label="Fermer" data-action="flash#dismiss">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    <% end %>
  </div>
<% end %>
