<% content_for :title, "Reservation #{@pack.name} | Le Bon Modele" %>

<%= render "home/header" %>

<main class="pt-28">
  <section class="px-4 py-10 md:px-6 lg:px-8 lg:py-14">
    <div class="mx-auto grid max-w-[1280px] gap-8 lg:grid-cols-[0.85fr_1.15fr]">
      <aside class="rounded-[28px] border border-[#E7E2DC] bg-white p-6 shadow-soft sm:p-8">
        <%= image_tag @pack.icon_path, alt: "", class: "h-16 w-12" %>
        <h1 class="mt-4 font-heading text-[34px] font-bold leading-none <%= @pack.accent_class %> sm:text-[42px]"><%= @pack.name %></h1>
        <p class="mt-6 text-[20px] font-bold text-brand-primary">Objectif :</p>
        <p class="mt-2 font-heading text-[30px] font-bold leading-[1.05] text-brand-text sm:text-[36px]"><%= @pack.objective %></p>
        <p class="mt-6 text-[18px] leading-[1.45] text-brand-text-secondary"><%= @pack.description %></p>
        <div class="mt-10 rounded-[24px] bg-brand-beige p-6">
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-brand-primary">Prix TTC</p>
          <p class="mt-2 font-heading text-[56px] font-black leading-none tracking-[-0.04em] text-brand-text"><%= euro_price(@pack.price_cents) %></p>
          <p class="mt-3 text-[16px] leading-[1.5] text-brand-text-secondary">Paiement securise par carte bancaire sur Stripe. L'adresse de facturation et le detail de la TVA apparaissent dans le formulaire de paiement.</p>
        </div>
      </aside>

      <article class="rounded-[28px] border border-[#E7E2DC] bg-white p-6 shadow-soft sm:p-8 lg:p-10">
        <p class="text-[20px] font-bold text-brand-primary">1. Choisissez votre rendez-vous</p>
        <h2 class="mt-2 font-heading text-[34px] font-bold leading-none text-brand-text sm:text-[44px]">Reservation et paiement</h2>

        <% if @booking.errors.any? %>
          <div class="mt-6 rounded-[20px] border border-brand-coral/30 bg-brand-coral/5 p-4 text-brand-coral">
            <p class="font-bold">Impossible de continuer :</p>
            <ul class="mt-2 list-disc pl-5">
              <% @booking.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: [@pack, @booking], class: "mt-8 space-y-8", data: { turbo: false } do |form| %>
          <div
            data-controller="booking-scheduler"
            data-booking-scheduler-available-dates-value="<%= @available_dates.map(&:iso8601).to_json %>"
            data-booking-scheduler-today-value="<%= @calendar_today.iso8601 %>"
            data-booking-scheduler-initial-month-value="<%= @initial_month %>"
            data-booking-scheduler-initial-date-value="<%= @initial_date %>"
          >
            <% if @slots_by_date.any? %>
              <div class="overflow-hidden rounded-[24px] border border-[#E7E2DC]">
                <div class="grid lg:grid-cols-2">
                  <div class="border-b border-[#E7E2DC] p-5 sm:p-6 lg:border-b-0 lg:border-r">
                    <p class="text-sm font-bold uppercase tracking-[0.12em] text-brand-text-secondary">Selectionnez une date</p>
                    <p class="mt-1 text-sm text-brand-text-secondary">Fuseau horaire : Europe/Paris</p>

                    <div class="mt-5 flex items-center justify-between">
                      <button type="button" data-action="booking-scheduler#previousMonth" class="flex h-10 w-10 items-center justify-center rounded-full text-brand-primary transition hover:bg-brand-beige" aria-label="Mois precedent">
                        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true"><path d="M15.41 7.41 14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
                      </button>
                      <p data-booking-scheduler-target="monthLabel" class="font-bold text-brand-text"></p>
                      <button type="button" data-action="booking-scheduler#nextMonth" class="flex h-10 w-10 items-center justify-center rounded-full text-brand-primary transition hover:bg-brand-beige" aria-label="Mois suivant">
                        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true"><path d="M8.59 16.59 13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
                      </button>
                    </div>

                    <div class="mt-4 grid grid-cols-7 gap-1 text-center text-[11px] font-bold uppercase tracking-[0.08em] text-brand-text-secondary">
                      <% %w[LUN. MAR. MER. JEU. VEN. SAM. DIM.].each do |weekday| %>
                        <span class="py-2"><%= weekday %></span>
                      <% end %>
                    </div>

                    <div data-booking-scheduler-target="calendar" class="grid grid-cols-7 gap-1"></div>
                  </div>

                  <div data-booking-scheduler-target="timesSection" class="p-5 sm:p-6">
                    <p data-booking-scheduler-target="selectedDayLabel" class="font-bold text-brand-text"></p>
                    <p class="mt-1 text-sm text-brand-text-secondary"><%= @pack.duration_minutes %> min</p>

                    <div class="mt-4 max-h-[320px] space-y-2 overflow-y-auto pr-1">
                      <% @slots_by_date.each do |date, slots| %>
                        <div data-booking-scheduler-target="timePanel" data-date="<%= date.iso8601 %>" class="space-y-3" hidden>
                          <% slots.each do |slot| %>
                            <label
                              data-booking-scheduler-target="timeSlot"
                              data-time="<%= paris_time(slot.starts_at) %>"
                              data-date-label="<%= paris_day_label(date) %>"
                              class="flex cursor-pointer items-center justify-center rounded-full border border-[#E7E2DC] bg-white px-4 py-3 font-bold text-brand-text transition hover:border-brand-primary"
                            >
                              <%= form.radio_button :availability_slot_id, slot.id, required: true, class: "sr-only", data: { action: "booking-scheduler#selectTime" } %>
                              <%= paris_time(slot.starts_at) %>
                            </label>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>

              <p class="mt-5 rounded-[18px] bg-brand-beige px-4 py-3 text-brand-text">
                <span class="font-bold text-brand-primary">Selection :</span>
                <span data-booking-scheduler-target="summary" class="ml-1"></span>
              </p>
            <% else %>
              <div class="rounded-[20px] border border-[#E7E2DC] bg-brand-beige p-5">
                <p class="font-bold text-brand-text">Aucun creneau n'est disponible pour le moment.</p>
                <p class="mt-2 text-brand-text-secondary">Revenez bientot ou contactez-nous pour ouvrir un nouveau rendez-vous.</p>
              </div>
            <% end %>
          </div>

          <div>
            <p class="text-[20px] font-bold text-brand-primary">2. Vos coordonnees</p>
            <div class="mt-4 grid gap-4 sm:grid-cols-2">
              <div class="sm:col-span-2">
                <%= form.label :customer_name, "Nom complet", class: "text-sm font-bold text-brand-text" %>
                <%= form.text_field :customer_name, required: true, class: "mt-2 w-full rounded-full border border-[#E7E2DC] bg-white px-5 py-4 text-brand-text outline-none focus:border-brand-primary" %>
              </div>
              <div>
                <%= form.label :customer_email, "Email", class: "text-sm font-bold text-brand-text" %>
                <%= form.email_field :customer_email, required: true, class: "mt-2 w-full rounded-full border border-[#E7E2DC] bg-white px-5 py-4 text-brand-text outline-none focus:border-brand-primary" %>
              </div>
              <div>
                <%= form.label :customer_phone, "Telephone", class: "text-sm font-bold text-brand-text" %>
                <%= form.telephone_field :customer_phone, class: "mt-2 w-full rounded-full border border-[#E7E2DC] bg-white px-5 py-4 text-brand-text outline-none focus:border-brand-primary" %>
              </div>
            </div>
          </div>

          <%= form.submit "Payer et confirmer le rendez-vous", disabled: @slots_by_date.empty?, class: "inline-flex min-h-[64px] w-full items-center justify-center rounded-full bg-brand-primary px-8 text-[18px] font-bold text-white transition-all duration-200 ease-out hover:-translate-y-[2px] hover:shadow-[0_14px_36px_rgba(31,95,60,0.22)] disabled:cursor-not-allowed disabled:opacity-50" %>
        <% end %>
      </article>
    </div>
  </section>
</main>

<%= render "home/footer" %>
