<% accent_class = local_assigns.fetch(:accent_class, "text-brand-accent") %>

<%= link_to path, class: "group block rounded-[28px] border border-[#E7E2DC] bg-white p-6 shadow-soft transition-all duration-300 ease-out hover:-translate-y-[4px] hover:bg-brand-beige hover:shadow-hover sm:p-8" do %>
  <div class="flex h-full flex-col">
    <%= image_tag icon_path, alt: "", class: "h-16 w-12" %>

    <h3 class="mt-4 font-heading text-[34px] font-bold leading-none <%= accent_class %> sm:text-[42px]"><%= title %></h3>
    <div class="mt-6 h-px w-full bg-[#D9D9D9]"></div>

    <div class="mt-6">
      <p class="text-[20px] font-bold text-brand-primary sm:text-[22px]">Objectif :</p>
      <p class="mt-2 font-heading text-[30px] font-bold leading-[1.05] text-brand-text sm:text-[36px]"><%= objective %></p>
    </div>

    <p class="mt-8 text-[18px] leading-[1.4] text-brand-text-secondary sm:text-[20px]"><%= description %></p>

    <div class="mt-10 flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <span class="inline-flex min-h-[64px] items-center justify-center rounded-full bg-brand-primary px-8 text-[18px] font-bold text-white transition group-hover:scale-[1.02]">
        Je choisis cette offre
      </span>

      <div class="font-heading leading-none text-brand-text">
        <span class="text-[64px] font-black tracking-[-0.04em]"><%= price %></span>
        <span class="ml-2 text-[26px] font-medium">TTC</span>
      </div>
    </div>
  </div>
<% end %>
