<% content_for :title, "Qui sommes nous ? | Le Bon Modele" %>

<%= render "home/header" %>

<main class="pt-28">
  <section class="px-6 py-14 lg:px-12">
    <div class="mx-auto grid max-w-[1280px] items-center gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="rounded-[28px] bg-brand-primary p-8 text-white shadow-brand">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-white/70">Notre mission</p>
        <h1 class="mt-4 font-heading text-5xl font-black leading-[0.95]">Rendre l'achat auto lisible.</h1>
        <p class="mt-6 text-lg leading-8 text-white/80">
          Le Bon Modele aide les acheteurs a poser les bonnes questions avant de choisir un modele, une annonce ou un financement.
        </p>
      </div>

      <div>
        <h2 class="font-heading text-4xl font-bold text-brand-primary">Deux experts, aucun interet a vous vendre une voiture.</h2>
        <p class="mt-6 text-lg leading-8 text-brand-text-secondary">
          Charles et Jules accompagnent les conducteurs qui veulent acheter avec methode. Ils comparent les modeles, lisent les annonces, cadrent les compromis et traduisent le marche auto en decisions simples.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          <div class="rounded-brand bg-white p-5 shadow-brand"><strong class="block text-3xl text-brand-accent">0</strong><span class="text-sm text-brand-text-secondary">commission vendeur</span></div>
          <div class="rounded-brand bg-white p-5 shadow-brand"><strong class="block text-3xl text-brand-coral">2</strong><span class="text-sm text-brand-text-secondary">regards experts</span></div>
          <div class="rounded-brand bg-white p-5 shadow-brand"><strong class="block text-3xl text-brand-primary">1</strong><span class="text-sm text-brand-text-secondary">choix clair</span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 py-14 lg:px-12">
    <div class="mx-auto grid max-w-[1280px] gap-6 md:grid-cols-3">
      <% [
        [ "Independance", "Nos recommandations ne dependent ni d'un concessionnaire, ni d'une plateforme d'annonces." ],
        [ "Pedagogie", "Nous expliquons les differences entre modeles, motorisations, finitions, garanties et couts d'usage." ],
        [ "Pragmatisme", "Nous partons de votre quotidien : trajets, budget, contraintes familiales, stationnement et envies." ]
      ].each do |title, body| %>
        <article class="rounded-[24px] border border-brand-border bg-white p-6 shadow-soft">
          <h3 class="font-heading text-2xl font-bold text-brand-primary"><%= title %></h3>
          <p class="mt-4 leading-7 text-brand-text-secondary"><%= body %></p>
        </article>
      <% end %>
    </div>
  </section>

  <%= render "home/contact_banner" %>
</main>

<%= render "home/footer" %>
