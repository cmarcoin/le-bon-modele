<section class="px-4 py-12 md:px-6 lg:px-8">
  <div class="relative mx-auto w-full max-w-[1280px]">
    <%= image_tag "/reference-assets/contact.gif", alt: "", aria: { hidden: true }, class: "contact-desktop-image" %>

    <div class="relative overflow-hidden rounded-[28px] bg-brand-primary-light">
      <%= image_tag "/reference-assets/trait.svg", alt: "", aria: { hidden: true }, class: "contact-trait" %>

      <div class="relative z-10 flex min-h-[320px] flex-col items-center justify-center gap-8 px-6 py-10 text-center md:px-8 lg:flex-row lg:items-center lg:justify-between lg:px-12 lg:text-left">
        <div class="hidden w-[280px] lg:block"></div>

        <div class="max-w-[520px]">
          <h2 class="font-heading text-[42px] font-bold leading-[0.95] text-brand-primary">Vous êtes perdu ?</h2>
          <p class="mt-3 text-[20px] leading-tight text-brand-primary">Nous répondons à toutes vos questions</p>
        </div>

        <%= link_to contact_path, class: "group inline-flex min-h-[64px] items-center justify-center gap-3 rounded-full bg-white px-8 text-[18px] font-bold text-brand-primary transition-all duration-200 ease-out hover:-translate-y-[2px] hover:bg-brand-primary hover:text-white" do %>
          Nous contacter
          <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-[2px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <path d="M3 7l9 6 9-6"></path>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</section>
