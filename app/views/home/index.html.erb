<!-- Header -->
<header class="w-full px-8 py-6 flex items-center justify-between bg-white">
  <!-- Logo -->
  <div class="flex items-center gap-3">
    <div class="w-12 h-12 bg-herve-green rounded flex items-center justify-center">
      <span class="text-white text-2xl font-bold">H</span>
    </div>
    <span class="text-herve-blue text-2xl font-bold">Herve</span>
  </div>

  <!-- Navigation Links -->
  <nav class="flex items-center gap-8">
    <a href="#" class="text-herve-blue font-medium">Accueil</a>
    <a href="#" class="text-herve-blue font-medium">Onglet</a>
    <a href="#" class="text-herve-blue font-medium">Onglet</a>
    <a href="#" class="text-herve-blue font-medium">Onglet</a>
    <a href="#" class="text-herve-blue font-medium">Onglet</a>
  </nav>

  <!-- Contact Button -->
  <button class="px-6 py-2 border-2 border-herve-blue rounded-lg text-herve-blue font-medium hover:bg-herve-blue hover:text-white transition-colors">
    Nous contacter
  </button>
</header>

<!-- Hero Section -->
<section class="relative w-full min-h-screen bg-white overflow-hidden">
  <!-- Background Wave Pattern -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 left-0 w-full h-full" style="background: linear-gradient(135deg, #E0F0FF 0%, transparent 50%); transform: rotate(-5deg); transform-origin: top left; width: 150%; height: 150%;"></div>
  </div>

  <div class="relative z-10 container mx-auto px-8 py-20 flex items-center gap-16">
    <!-- Left Content -->
    <div class="flex-1 max-w-2xl">
      <!-- Headline -->
      <h1 class="text-5xl font-bold text-herve-blue mb-6 leading-tight">
        CHOISISSEZ LA BONNE VOITURE, PAS CELLE QU'ON VEUT VOUS VENDRE.
        <span class="inline-block w-3 h-3 bg-herve-green rounded-full ml-2"></span>
      </h1>

      <!-- Paragraph -->
      <p class="text-lg text-herve-blue mb-8 leading-relaxed">
        Nous vous aidons à trouver le véhicule et le financement adaptés à vos besoins, en toute indépendance.
      </p>

      <!-- CTA Button -->
      <button class="px-8 py-4 bg-herve-blue text-white rounded-lg font-medium flex items-center gap-2 hover:bg-opacity-90 transition-colors">
        Faire mon audit gratuit
        <svg class="w-5 h-5" fill="#FF0000" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"/>
        </svg>
      </button>
    </div>

    <!-- Right Illustration -->
    <div class="flex-1 max-w-lg relative">
      <!-- Speech Bubble -->
      <div class="absolute top-0 right-0 bg-herve-green rounded-2xl px-6 py-4 shadow-lg z-20" style="transform: translateY(-20px);">
        <p class="text-white font-medium">C'est quoi les différences?</p>
        <div class="absolute bottom-0 left-1/2 transform -translate-x-1/2 translate-y-full">
          <div class="w-0 h-0 border-l-8 border-r-8 border-t-8 border-transparent border-t-herve-green"></div>
        </div>
      </div>

      <!-- Illustration Container -->
      <div class="mt-24 relative h-96">
        <!-- People and Cars Illustration -->
        <div class="relative h-full">
          <!-- People silhouettes -->
          <div class="absolute bottom-0 left-0 right-0 flex items-end justify-around px-8">
            <!-- Child (left) - smaller -->
            <div class="flex flex-col items-center">
              <div class="w-12 h-12 rounded-full bg-white border-2 border-herve-blue mb-2"></div>
              <div class="w-10 h-20 bg-white border-2 border-herve-blue rounded-t-lg"></div>
              <div class="flex gap-2 mt-1">
                <div class="w-4 h-8 bg-white border-2 border-herve-blue rounded"></div>
                <div class="w-4 h-8 bg-white border-2 border-herve-blue rounded"></div>
              </div>
            </div>

            <!-- Woman (middle) -->
            <div class="flex flex-col items-center">
              <div class="w-14 h-14 rounded-full bg-white border-2 border-herve-blue mb-2"></div>
              <div class="w-12 h-28 bg-white border-2 border-herve-blue rounded-t-lg"></div>
              <div class="flex gap-2 mt-1">
                <div class="w-5 h-10 bg-white border-2 border-herve-blue rounded"></div>
                <div class="w-5 h-10 bg-white border-2 border-herve-blue rounded"></div>
              </div>
            </div>

            <!-- Man (right) with hand on head -->
            <div class="flex flex-col items-center relative">
              <div class="w-14 h-14 rounded-full bg-white border-2 border-herve-blue mb-2"></div>
              <!-- Hand on head -->
              <div class="absolute top-0 right-0 w-6 h-8 bg-white border-2 border-herve-blue rounded-full transform rotate-12"></div>
              <div class="w-12 h-28 bg-white border-2 border-herve-blue rounded-t-lg"></div>
              <div class="flex gap-2 mt-1">
                <div class="w-5 h-10 bg-white border-2 border-herve-blue rounded"></div>
                <div class="w-5 h-10 bg-white border-2 border-herve-blue rounded"></div>
              </div>
            </div>
          </div>

          <!-- Cars at the bottom -->
          <div class="absolute bottom-0 left-0 right-0 flex justify-center gap-12 -mb-8">
            <!-- Car 1 -->
            <div class="w-40 h-20 bg-white rounded-xl shadow-lg border-2 border-herve-blue relative overflow-hidden">
              <div class="absolute top-1 left-2 right-2 h-10 bg-herve-light-blue rounded-lg"></div>
              <div class="absolute bottom-1 left-2 right-2 h-3 bg-herve-light-blue rounded"></div>
              <div class="absolute bottom-2 left-4 w-8 h-8 rounded-full bg-herve-blue opacity-20"></div>
              <div class="absolute bottom-2 right-4 w-8 h-8 rounded-full bg-herve-blue opacity-20"></div>
            </div>
            <!-- Car 2 -->
            <div class="w-40 h-20 bg-white rounded-xl shadow-lg border-2 border-herve-blue relative overflow-hidden">
              <div class="absolute top-1 left-2 right-2 h-10 bg-herve-light-blue rounded-lg"></div>
              <div class="absolute bottom-1 left-2 right-2 h-3 bg-herve-light-blue rounded"></div>
              <div class="absolute bottom-2 left-4 w-8 h-8 rounded-full bg-herve-blue opacity-20"></div>
              <div class="absolute bottom-2 right-4 w-8 h-8 rounded-full bg-herve-blue opacity-20"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Bottom Section -->
<section class="w-full bg-herve-blue rounded-t-[60px] py-16 -mt-20 relative z-0">
  <div class="container mx-auto px-8 text-center">
    <h2 class="text-5xl font-bold text-white">Notre Approche</h2>
  </div>
</section>

