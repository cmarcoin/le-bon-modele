<% nav_items = [
  [ "Accueil", root_path ],
  [ "Qui sommes nous ?", about_path ],
  [ "FAQ", faq_path ],
  [ "Starter Pack", starter_pack_path ],
  [ "Pack Premium", pack_premium_path ]
] %>

<header class="site-header" data-controller="site-header" data-site-header-scrolled-class="is-scrolled">
  <div class="site-header-nav">
    <div class="container-site flex items-center justify-between gap-6 px-2 py-4 lg:px-0">
    <%= link_to root_path, class: "flex shrink-0 items-center", aria: { label: "Le Bon Modèle" } do %>
      <%= image_tag "/reference-assets/logo.png", alt: "Logo", class: "main-logo", id: "headerLogo" %>
    <% end %>

    <nav class="hidden items-center gap-4 lg:flex" aria-label="Navigation principale">
      <% nav_items.each do |label, path| %>
        <%= link_to label, path, class: class_names("nav-link", "active": current_page?(path)) %>
      <% end %>
      <%= link_to contact_path, class: "group inline-flex min-h-[48px] items-center justify-center gap-3 rounded-full border-2 border-brand-primary bg-white px-8 text-[18px] font-bold text-brand-primary transition-all duration-200 ease-out hover:-translate-y-[2px] hover:scale-[1.02] hover:bg-brand-primary hover:text-white" do %>
        Contact
        <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-[2px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="M3 7l9 6 9-6"></path>
        </svg>
      <% end %>
    </nav>

    <button type="button" class="relative z-[6000] p-2 lg:hidden" aria-label="Ouvrir le menu" data-action="site-header#toggle">
      <span data-site-header-target="openIcon">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </span>
      <span class="hidden" data-site-header-target="closeIcon">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M6 18L18 6M6 6l12 12" />
        </svg>
      </span>
    </button>
    </div>
  </div>

  <div class="mobile-overlay-fixed" data-site-header-target="overlay">
    <nav class="flex h-full flex-col items-center justify-center gap-8" aria-label="Navigation mobile">
      <% nav_items.each do |label, path| %>
        <%= link_to label, path, class: "text-2xl font-bold text-brand-primary", data: { action: "site-header#close" } %>
      <% end %>
      <%= link_to "Contact", contact_path, class: "mt-4 rounded-full bg-brand-primary px-10 py-4 font-bold text-white", data: { action: "site-header#close" } %>
    </nav>
  </div>
</header>

<%= render "shared/flash", class: "container-site mx-auto px-6 pb-4 pt-20 lg:px-8" %>
