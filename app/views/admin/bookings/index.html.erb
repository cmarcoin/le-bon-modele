<% content_for :title, "Reservations | Admin" %>

<%= render "admin/nav" %>

<main class="px-6 py-10">
  <div class="mx-auto max-w-[1280px]">
    <h1 class="font-heading text-4xl font-bold text-brand-primary">Reservations</h1>

    <div class="mt-8 overflow-hidden rounded-[28px] border border-[#E7E2DC] bg-white shadow-soft">
      <table class="w-full min-w-[980px] text-left">
        <thead class="bg-brand-beige text-sm uppercase tracking-[0.12em] text-brand-text-secondary">
          <tr>
            <th class="px-5 py-4">Client</th>
            <th class="px-5 py-4">Pack</th>
            <th class="px-5 py-4">Rendez-vous</th>
            <th class="px-5 py-4">Paiement</th>
            <th class="px-5 py-4">Montant</th>
            <th class="px-5 py-4"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[#E7E2DC]">
          <% @bookings.each do |booking| %>
            <tr>
              <td class="px-5 py-4">
                <p class="font-bold"><%= booking.customer_name %></p>
                <p class="text-sm text-brand-text-secondary"><%= booking.customer_email %></p>
              </td>
              <td class="px-5 py-4"><%= booking.pack.name %></td>
              <td class="px-5 py-4"><%= paris_datetime(booking.availability_slot.starts_at) %></td>
              <td class="px-5 py-4"><%= booking.status %></td>
              <td class="px-5 py-4 font-bold"><%= euro_price(booking.amount_cents) %></td>
              <td class="px-5 py-4 text-right"><%= link_to "Voir", admin_booking_path(booking), class: "font-bold text-brand-primary" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</main>
