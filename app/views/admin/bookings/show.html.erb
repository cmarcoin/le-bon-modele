<% content_for :title, "Réservation ##{@booking.id} | Admin" %>

<%= render "admin/nav" %>

<main class="px-6 py-10">
  <div class="mx-auto max-w-4xl rounded-[28px] border border-[#E7E2DC] bg-white p-8 shadow-soft">
    <p class="text-sm font-bold uppercase tracking-[0.2em] text-brand-text-secondary">Réservation #<%= @booking.id %></p>
    <h1 class="mt-2 font-heading text-4xl font-bold text-brand-primary"><%= @booking.customer_name %></h1>

    <dl class="mt-8 grid gap-5 sm:grid-cols-2">
      <div class="rounded-[20px] bg-brand-beige p-5">
        <dt class="text-sm font-bold uppercase tracking-[0.12em] text-brand-text-secondary">Pack</dt>
        <dd class="mt-2 font-bold"><%= @booking.pack.name %></dd>
      </div>
      <div class="rounded-[20px] bg-brand-beige p-5">
        <dt class="text-sm font-bold uppercase tracking-[0.12em] text-brand-text-secondary">Statut</dt>
        <dd class="mt-2 font-bold"><%= @booking.status %></dd>
      </div>
      <div class="rounded-[20px] bg-brand-beige p-5">
        <dt class="text-sm font-bold uppercase tracking-[0.12em] text-brand-text-secondary">Email</dt>
        <dd class="mt-2 font-bold"><%= @booking.customer_email %></dd>
      </div>
      <div class="rounded-[20px] bg-brand-beige p-5">
        <dt class="text-sm font-bold uppercase tracking-[0.12em] text-brand-text-secondary">Téléphone</dt>
        <dd class="mt-2 font-bold"><%= @booking.customer_phone.presence || "Non renseigné" %></dd>
      </div>
      <div class="rounded-[20px] bg-brand-beige p-5">
        <dt class="text-sm font-bold uppercase tracking-[0.12em] text-brand-text-secondary">Rendez-vous</dt>
        <dd class="mt-2 font-bold"><%= paris_datetime(@booking.availability_slot.starts_at) %></dd>
      </div>
      <div class="rounded-[20px] bg-brand-beige p-5">
        <dt class="text-sm font-bold uppercase tracking-[0.12em] text-brand-text-secondary">Montant</dt>
        <dd class="mt-2 font-bold"><%= euro_price(@booking.amount_cents) %> TTC</dd>
      </div>
    </dl>

    <% if @booking.payment_transaction %>
      <section class="mt-8 rounded-[20px] border border-[#E7E2DC] p-5">
        <h2 class="font-heading text-2xl font-bold text-brand-text">Transaction Stripe</h2>
        <p class="mt-4 text-sm"><strong>Session :</strong> <%= @booking.payment_transaction.stripe_checkout_session_id %></p>
        <p class="mt-2 text-sm"><strong>Payment intent :</strong> <%= @booking.payment_transaction.stripe_payment_intent_id.presence || "En attente" %></p>
        <p class="mt-2 text-sm"><strong>TVA :</strong> <%= euro_price(@booking.payment_transaction.tax_amount_cents) %></p>
      </section>
    <% end %>

    <div class="mt-8 flex flex-wrap gap-4">
      <%= link_to "Ajouter à Google Calendar", google_calendar_url_for(@booking), target: "_blank", rel: "noopener", class: "inline-flex min-h-[48px] items-center rounded-full bg-brand-primary px-6 font-bold text-white" %>
      <%= link_to "Retour aux réservations", admin_bookings_path, class: "inline-flex min-h-[48px] items-center rounded-full bg-brand-beige px-6 font-bold text-brand-text" %>
      <%= button_to "Supprimer la réservation", admin_booking_path(@booking), method: :delete, class: "inline-flex min-h-[48px] items-center rounded-full bg-brand-coral px-6 font-bold text-white", data: { turbo_confirm: "Supprimer cette réservation ? Cette action est irréversible." } %>
    </div>
  </div>
</main>
