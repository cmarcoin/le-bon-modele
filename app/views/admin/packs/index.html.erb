<% content_for :title, "Packs | Admin" %>

<%= render "admin/nav" %>

<main class="px-6 py-10">
  <div class="mx-auto max-w-[1280px]">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <h1 class="font-heading text-4xl font-bold text-brand-primary">Packs</h1>
      <%= button_to "Synchroniser tout avec Stripe", sync_stripe_admin_packs_path, method: :post, form: { class: "inline" }, class: "inline-flex min-h-[52px] items-center rounded-full bg-brand-primary px-6 font-bold text-white" %>
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      <% @packs.each do |pack| %>
        <article class="rounded-[28px] border border-[#E7E2DC] bg-white p-6 shadow-soft">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="font-heading text-3xl font-bold <%= pack.accent_class %>"><%= pack.name %></h2>
              <p class="mt-2 text-brand-text-secondary"><%= pack.objective %></p>
            </div>
            <span class="rounded-full bg-brand-beige px-4 py-2 text-sm font-bold"><%= pack.active? ? "Actif" : "Inactif" %></span>
          </div>
          <p class="mt-6 font-heading text-5xl font-black text-brand-text"><%= euro_price(pack.price_cents) %></p>
          <p class="mt-2 text-brand-text-secondary"><%= pack.duration_minutes %> min par rendez-vous</p>
          <p class="mt-4 text-sm text-brand-text-secondary">
            <% if pack.stripe_ready? %>
              Stripe: <%= pack.stripe_product_id %> / <%= pack.stripe_price_id %>
            <% else %>
              Stripe: non synchronisé
            <% end %>
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <%= link_to "Modifier", edit_admin_pack_path(pack), class: "inline-flex min-h-[48px] items-center rounded-full bg-brand-primary px-6 font-bold text-white" %>
            <%= button_to "Synchroniser Stripe", sync_stripe_admin_pack_path(pack), method: :post, form: { class: "inline" }, class: "inline-flex min-h-[48px] items-center rounded-full border border-[#E7E2DC] px-6 font-bold text-brand-text" %>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</main>
