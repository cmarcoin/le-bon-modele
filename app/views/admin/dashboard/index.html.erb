<% content_for :title, "Admin | Le Bon Modèle" %>

<%= render "admin/nav" %>

<main class="px-6 py-10">
  <div class="mx-auto max-w-[1280px]">
    <h1 class="font-heading text-4xl font-bold text-brand-primary">Dashboard</h1>

    <div class="mt-8 grid gap-6 lg:grid-cols-3">
      <%= link_to admin_packs_path, class: "rounded-[28px] border border-[#E7E2DC] bg-white p-6 shadow-soft" do %>
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-brand-text-secondary">Packs</p>
        <p class="mt-3 font-heading text-4xl font-black text-brand-text"><%= @packs.count %></p>
      <% end %>
      <%= link_to admin_availability_slots_path, class: "rounded-[28px] border border-[#E7E2DC] bg-white p-6 shadow-soft" do %>
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-brand-text-secondary">Créneaux à venir</p>
        <p class="mt-3 font-heading text-4xl font-black text-brand-text"><%= @upcoming_slots.count %></p>
      <% end %>
      <%= link_to admin_bookings_path, class: "rounded-[28px] border border-[#E7E2DC] bg-white p-6 shadow-soft" do %>
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-brand-text-secondary">Réservations récentes</p>
        <p class="mt-3 font-heading text-4xl font-black text-brand-text"><%= @recent_bookings.count %></p>
      <% end %>
    </div>

    <div class="mt-10 grid gap-8 lg:grid-cols-2">
      <section class="rounded-[28px] border border-[#E7E2DC] bg-white p-6 shadow-soft">
        <h2 class="font-heading text-2xl font-bold text-brand-text">Prochains créneaux</h2>
        <div class="mt-5 space-y-3">
          <% @upcoming_slots.each do |slot| %>
            <div class="rounded-[18px] bg-brand-beige p-4">
              <p class="font-bold"><%= paris_datetime(slot.starts_at) %></p>
              <p class="text-sm text-brand-text-secondary"><%= slot.pack&.name || "Tous les packs" %></p>
            </div>
          <% end %>
        </div>
      </section>

      <section class="rounded-[28px] border border-[#E7E2DC] bg-white p-6 shadow-soft">
        <h2 class="font-heading text-2xl font-bold text-brand-text">Dernières réservations</h2>
        <div class="mt-5 space-y-3">
          <% @recent_bookings.each do |booking| %>
            <%= link_to admin_booking_path(booking), class: "block rounded-[18px] bg-brand-beige p-4" do %>
              <p class="font-bold"><%= booking.customer_name %> - <%= booking.pack.name %></p>
              <p class="text-sm text-brand-text-secondary"><%= booking.status %> - <%= euro_price(booking.amount_cents) %></p>
            <% end %>
          <% end %>
        </div>
      </section>
    </div>
  </div>
</main>
