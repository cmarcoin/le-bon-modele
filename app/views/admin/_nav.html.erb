<header class="border-b border-[#E7E2DC] bg-white">
  <div class="mx-auto flex max-w-[1280px] flex-col gap-4 px-6 py-5 sm:flex-row sm:items-center sm:justify-between">
    <%= link_to "Admin Le Bon Modèle", admin_root_path, class: "font-heading text-2xl font-bold text-brand-primary" %>
    <nav class="flex flex-wrap items-center gap-3 text-sm font-bold text-brand-text">
      <%= link_to "Dashboard", admin_root_path, class: "rounded-full bg-brand-beige px-4 py-2" %>
      <%= link_to "Packs", admin_packs_path, class: "rounded-full bg-brand-beige px-4 py-2" %>
      <%= link_to "Agenda", admin_availability_slots_path, class: "rounded-full bg-brand-beige px-4 py-2" %>
      <%= link_to "Réservations", admin_bookings_path, class: "rounded-full bg-brand-beige px-4 py-2" %>
      <%= button_to "Déconnexion", destroy_user_session_path, method: :delete, class: "rounded-full bg-brand-primary px-4 py-2 text-white" %>
    </nav>
  </div>
</header>

<%= render "shared/flash", class: "mx-auto max-w-[1280px] px-6 pb-4" %>
