<% content_for :title, "Connexion | Le Bon Modèle" %>

<% input_class = "mt-2 w-full rounded-full border border-[#E7E2DC] bg-white px-5 py-4 text-brand-text outline-none transition focus:border-brand-primary" %>

<%= render layout: "devise/shared/auth_shell" do %>
  <article class="rounded-[28px] border border-[#E7E2DC] bg-white p-6 shadow-brand sm:p-8">
    <p class="text-sm font-bold uppercase tracking-[0.2em] text-brand-coral">Administration</p>
    <h1 class="mt-3 font-heading text-[34px] font-bold leading-none text-brand-primary sm:text-[40px]">Connexion</h1>
    <p class="mt-3 text-[16px] leading-relaxed text-brand-text-secondary">
      Accédez à votre espace pour gérer les packs, créneaux et réservations.
    </p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8 space-y-5" }) do |form| %>
      <div>
        <%= form.label :email, "Email", class: "text-sm font-bold text-brand-text" %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email", required: true, class: input_class %>
      </div>

      <div>
        <%= form.label :password, "Mot de passe", class: "text-sm font-bold text-brand-text" %>
        <%= form.password_field :password, autocomplete: "current-password", required: true, class: input_class %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex cursor-pointer items-center gap-3 text-sm font-medium text-brand-text-secondary">
          <%= form.check_box :remember_me, class: "h-4 w-4 accent-brand-primary" %>
          Se souvenir de moi
        </label>
      <% end %>

      <%= form.submit "Se connecter", class: "inline-flex min-h-[60px] w-full items-center justify-center rounded-full bg-brand-primary px-8 text-[18px] font-bold text-white transition-all duration-200 ease-out hover:-translate-y-[2px] hover:shadow-[0_14px_36px_rgba(31,95,60,0.22)]" %>
    <% end %>

    <div class="mt-6 border-t border-[#E7E2DC] pt-6">
      <%= render "devise/shared/links" %>
    </div>
  </article>
<% end %>
